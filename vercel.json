{
  "crons": [
    {
      "path": "/api/pulse?mode=checkin",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/activation",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/augment-observations",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/refresh-voicecards",
      "schedule": "0 10 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/health", "destination": "/api/admin?mode=health" },
    { "source": "/api/recrawl", "destination": "/api/admin?mode=recrawl" },
    { "source": "/api/admin/metrics", "destination": "/api/admin?mode=metrics" }
  ]
}
